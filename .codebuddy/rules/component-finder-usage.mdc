## 四、代码示例

### 4.1 UI 弹窗组件（UILayerBase）

```csharp
using UnityEngine;
using UnityEngine.UI;
using SimpleSolitaire.Utility;

public class MyDialog : UILayerBase
{
    [Header("UI 引用（可选配置）")]
    [SerializeField] private Text _titleText;
    [SerializeField] private Text _messageText;
    [SerializeField] private Button _confirmButton;
    [SerializeField] private Button _cancelButton;
    
    protected override void OnBindComponents()
    {
        // 使用 ComponentFinder 自动查找，无需手动拖拽
        _titleText = this.Get<Text>("Header/TitleText");
        _messageText = this.Get<Text>("Content/MessageText");
        _confirmButton = this.Get<Button>("Footer/ConfirmButton");
        _cancelButton = this.Get<Button>("Footer/CancelButton");
        
        // 验证所有必需组件
        ValidateComponents();
    }
    
    private void ValidateComponents()
    {
        if (_titleText == null)
            Debug.LogError($"[{nameof(MyDialog)}] 未找到 TitleText");
        if (_confirmButton == null)
            Debug.LogError($"[{nameof(MyDialog)}] 未找到 ConfirmButton");
    }
}
```

### 4.2 卡牌组件（Card）

```csharp
using UnityEngine;
using UnityEngine.UI;
using SimpleSolitaire.Utility;

public class WordSolitaireCard : Card
{
    [Header("UI 组件（可选配置）")]
    [SerializeField] private GameObject _frontContainer;
    [SerializeField] private Image _frontNormalImage;
    [SerializeField] private Text _wordText;
    
    protected void Awake()
    {
        // 自动查找背景图（从基类继承）
        if (BackgroundImage == null)
        {
            BackgroundImage = this.Get<Image>("Background");
        }
        
        // 自动查找 Front 相关组件
        if (_frontContainer == null)
        {
            _frontContainer = this.Get<Transform>("Front")?.gameObject;
            
            if (_frontContainer != null)
            {
                _frontNormalImage = this.Get<Image>("Front/FrontNormal");
                _wordText = this.Get<Text>("Front/Text");
                
                // 验证关键组件
                if (_wordText == null)
                {
                    Debug.LogError($"[{nameof(WordSolitaireCard)}] 未找到 Text 组件");
                }
            }
        }
    }
}
```

### 4.3 获取跨 GameObject 引用

```csharp
public class GameUI : MonoBehaviour
{
    private GameManager _gameManager;
    private CardLogic _cardLogic;
    
    protected void Awake()
    {
        // 获取场景中的单例组件
        _gameManager = this.FindInScene<GameManager>();
        _cardLogic = this.FindInScene<CardLogic>();
        
        if (_gameManager == null)
        {
            Debug.LogError($"[{nameof(GameUI)}] 未找到 GameManager");
        }
    }
}
```

