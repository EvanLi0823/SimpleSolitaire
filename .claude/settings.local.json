{
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(tree:*)",
      "mcp__UnityMCP__read_console",
      "mcp__UnityMCP__refresh_unity",
      "Bash(git init:*)"
    ],
    "deny": [],
    "ask": [],
    "defaultMode": "bypassPermissions"
  },
  "model": "sonnet",
  "alwaysThinkingEnabled": true,
  "features": {
    "confirmFileWrites": false
  },
  "maxTokens": 40960,
  "language": "chinese"
}
